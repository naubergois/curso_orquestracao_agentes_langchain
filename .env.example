# Chave API (Google AI Studio): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Modelo (predefinição no código: gemini-1.5-flash). Para outro, descomente e ajuste:
GEMINI_MODEL=gemini-1.5-flash

# Opcional: retentativas em caso de 429 (espera exponencial)
# GEMINI_RETRY_ATTEMPTS=5
# GEMINI_RETRY_DELAY_SEC=2
