# Chave API (Google AI Studio): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Exercício 00 (`exercicios/00_alo_mundo/`): Docker predefinido = Jupyter Lab + caderno aberto (`./run.sh`). Uma execução no terminal: `./run.sh --once`.
# Usa `GEMINI_MODEL` abaixo.

# Jupyter no Docker: o compose fixa acesso sem token (só localhost). Opcional: ficheiro do caderno
# EX00_NOTEBOOK=exercicio_0_sem_ecra.ipynb

# Exercício 01 com ecrã (`exercicios/01_alo_mundo_com_ecra/`) e sem ecrã (`exercicios/01_alo_mundo_sem_ecra/`):
# nome do modelo com `GEMINI_MODEL` (Gemini 2.x). Vários exemplos usam a mesma variável.
GEMINI_MODEL=gemini-2.0-flash

# Jupyter ex. 1 sem ecrã — ficheiro do caderno (opcional; ver run_jupyter.sh nesta pasta)
# EX01_NOTEBOOK=exercicio_1_sem_ecra.ipynb

# Exercício 02 com ecrã (`exercicios/02_nerd_sarcastico_com_ecra/`): modelo via `GEMINI_MODEL_EX02` (predefinição no código: gemini-2.0-flash).
# Exercício 02 sem ecrã: `exercicios/02_nerd_sarcastico_sem_ecra/`.
# Jupyter ex. 2 sem ecrã — opcional: EX02_NOTEBOOK=exercicio_2_sem_ecra.ipynb
# GEMINI_MODEL_EX02=gemini-2.5-flash

# Opcional: exercício 02 — nerd sarcástico (0.0–2.0). Legado: ANTI_COACH_TEMPERATURE
# NERD_SARCASTICO_TEMPERATURE=0.75

# Exercício 03 com ecrã (`exercicios/03_calculadora/`) e sem ecrã (`exercicios/03_calculadora_sem_ecra/`):
# mesmo modelo `GEMINI_MODEL` (ReAct + tool `calculadora`).
# Jupyter ex. 3 sem ecrã — opcional: EX03_NOTEBOOK=exercicio_3_sem_ecra.ipynb

# Exercício 04 com ecrã (`exercicios/04_fatores_risco_pacientes/`) e sem ecrã (`exercicios/04_fatores_risco_pacientes_sem_ecra/`):
# **DeepSeek** (API OpenAI-compatível): https://platform.deepseek.com — chave em `DEEPSEEK_API_KEY`.
# PostgreSQL no Docker; `DATABASE_URL` é definido pelo compose dentro dos contentores.
# No host, o Postgres do compose expõe a porta **5433** por defeito (`POSTGRES_PORT`).
# DATABASE_URL=postgresql://curso:curso@127.0.0.1:5433/pacientes
# DEEPSEEK_API_KEY=
# DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_API_BASE=https://api.deepseek.com
# Jupyter ex. 4 sem ecrã — opcional: EX04_NOTEBOOK=exercicio_4_sem_ecra.ipynb

# Opcional: retentativas 429 no ex. 4 (também lê `GEMINI_RETRY_*` por compatibilidade)
# LLM_RETRY_ATTEMPTS=8
# LLM_RETRY_DELAY_SEC=5
# LLM_RETRY_MAX_SLEEP_SEC=120

# *Fallback* de nomes de modelo (ver `exercicios/lib_llm_fallback.py` e GUIA §9.2)
# GEMINI_MODEL_FALLBACKS=gemini-2.5-flash,gemini-2.0-flash-lite
# DEEPSEEK_MODEL_FALLBACKS=deepseek-reasoner
# LLM_FALLBACK_SKIP_SMOKE_TEST=0

# Exercício 05 sem ecrã (`exercicios/05_prompt_templates_lcel_sem_ecra/`): LCEL + `ChatPromptTemplate` (sem Streamlit).
# Usa `GEMINI_MODEL_EX05` se definido; senão cai para `GEMINI_MODEL` (Gemini 2.x).
# GEMINI_MODEL_EX05=gemini-2.0-flash
# Jupyter ex. 5 sem ecrã — opcional: EX05_NOTEBOOK=exercicio_5_sem_ecra.ipynb

# Exercício 06 sem ecrã (`exercicios/06_memoria_langchain_sem_ecra/`): histórico de chat, `RunnableWithMessageHistory`, `trim_messages`.
# Usa `GEMINI_MODEL_EX06` se definido; senão cai para `GEMINI_MODEL` (Gemini 2.x). `GEMINI_MODEL_FALLBACKS` opcional.
# GEMINI_MODEL_EX06=gemini-2.0-flash
# Jupyter ex. 6 sem ecrã — opcional: EX06_NOTEBOOK=exercicio_6_sem_ecra.ipynb

# Exercício 07 com ecrã (`exercicios/07_precos_clima_cotacao/`) e sem ecrã (`exercicios/07_precos_clima_cotacao_sem_ecra/`):
# agente ReAct com várias *tools* (MLB, clima Fortaleza, USD/BRL, EUR/BRL, Wikipédia PT, DuckDuckGo, CEP, feriados BR, calculadora, data/hora, conversão °C→°F, URLs, SHA-256). Requer **rede**.
# Opcional: `GEMINI_MODEL_EX07`; senão `GEMINI_MODEL`. `GEMINI_MODEL_FALLBACKS` opcional.
# GEMINI_MODEL_EX07=gemini-2.0-flash
# Jupyter ex. 7 sem ecrã — opcional: EX07_NOTEBOOK=exercicio_7_sem_ecra.ipynb

# Exercício 08 sem ecrã (`exercicios/08_chains_complexas_sem_ecra/`): LCEL composto (Parallel, Branch, Lambda…). Opcional `GEMINI_MODEL_EX08`; senão `GEMINI_MODEL`. `GEMINI_MODEL_FALLBACKS` opcional.
# GEMINI_MODEL_EX08=gemini-2.0-flash
# Jupyter ex. 8 sem ecrã — opcional: EX08_NOTEBOOK=exercicio_8_sem_ecra.ipynb

# Exercício 09 com ecrã (`exercicios/09_rag_juridico_com_ecra/`) e sem ecrã (`exercicios/09_rag_juridico_sem_ecra/`):
# RAG sobre PDFs gerados + Chroma. Chat: opcional `GEMINI_MODEL_EX09`; senão `GEMINI_MODEL`.
# Embeddings Gemini (API actual; **sem** prefixo `models/`): `GEMINI_EMBEDDING_MODEL` (predef.: gemini-embedding-001),
# `GEMINI_EMBEDDING_MODEL_ALT` (predef.: gemini-embedding-2-preview). Legado: `GEMINI_EMBEDDING_MODEL_004` / `GEMINI_EMBEDDING_MODEL_LEGACY` são mapeados para estes nomes.
# Modelos gemini-embedding-2-*: opcional `GEMINI_EMBEDDING_2_OUTPUT_DIMENSIONALITY` (predef. 768; `none`/`0` = omitir) e
# `GEMINI_EMBEDDING_2_BATCH_SIZE` (1–100, predef. 16) se a indexação falhar com «list index out of range».
# FastEmbed local: `FASTEMBED_MODEL` (predef.: sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2), `FASTEMBED_CACHE_DIR`.
# Agente PDF: `ingest_rag.pipeline_completo(..., fonte_pdfs="agente")` ou módulo `agent_gerador_pdfs`.
# Telemetria Chroma: `ANONYMIZED_TELEMETRY=false` e `CHROMADB_ANONYMIZED_TELEMETRY=false`. Se ainda aparecer
# «capture() takes 1 positional argument but 3 were given», o ambiente tem posthog>=6 — use o pin nos requirements
# do ex. 9 ou: `pip install 'posthog<6'`.
# GEMINI_MODEL_EX09=gemini-2.0-flash
# PostgreSQL (RAG híbrido — processos fictícios): no Docker Compose do ex. 9 usa-se `DATABASE_URL` automático.
# Fora do Docker (Postgres na 5434): `DATABASE_URL=postgresql://curso:curso@127.0.0.1:5434/juridico` ou `EX09_DATABASE_URL`.
# `EX09_POSTGRES_PORT` só altera o URL por defeito em `db_processos.database_url()` quando `DATABASE_URL` está vazio.
# Jupyter ex. 9 sem ecrã — opcional: EX09_NOTEBOOK=exercicio_9_sem_ecra.ipynb

# Exercício 10 com ecrã (`exercicios/10_triagem_imagens_patologia_com_ecra/`) e sem ecrã (`exercicios/10_triagem_imagens_patologia_sem_ecra/`):
# triagem com **DermaMNIST** (MedMNIST), classificador sklearn, **MongoDB** e agente ReAct.
# MongoDB no host (Docker): porta **27018** por defeito (`MONGO_EX10_PORT`). URI no contentor:
# `mongodb://curso:curso@mongo:27017/triagem?authSource=admin` (o compose define `MONGODB_URI`).
# Opcional no host: `MONGODB_URI=mongodb://curso:curso@127.0.0.1:27018/triagem?authSource=admin`
# Patologia com peso extra na prioridade (índice 0–6 DermaMNIST): predef. **4 = melanoma**.
# EX10_PATOLOGIA_INDICE=4
# GEMINI_MODEL_EX10=gemini-2.0-flash
# Jupyter ex. 10 sem ecrã — opcional: EX10_NOTEBOOK=exercicio_10_sem_ecra.ipynb

# Exercício 11 sem ecrã (`exercicios/11_pydantic_sem_ecra/`): **Pydantic v2** (validação local); secção opcional com Gemini estruturado.
# Usa `GEMINI_MODEL_EX11` se definido; senão cai para `GEMINI_MODEL` (Gemini 2.x).
# GEMINI_MODEL_EX11=gemini-2.0-flash
# Jupyter ex. 11 sem ecrã — opcional: EX11_NOTEBOOK=exercicio_11_sem_ecra.ipynb

