# Chave API (Google AI Studio): https://aistudio.google.com/apikey
GOOGLE_API_KEY=

# Exercício 01: modelo no `.env` (ex.: plano gratuito)
GEMINI_MODEL=gemini-1.5-flash

# Exercício 02 (`exercicios/02_nerd_sarcastico/`): por defeito gemini-2.0-flash no código.
# GEMINI_MODEL_EX02=gemini-2.5-flash

# Opcional: exercício 02 — nerd sarcástico (0.0–2.0). Legado: ANTI_COACH_TEMPERATURE
# NERD_SARCASTICO_TEMPERATURE=0.75

# Opcional: retentativas em caso de 429 (espera exponencial)
# GEMINI_RETRY_ATTEMPTS=5
# GEMINI_RETRY_DELAY_SEC=2
