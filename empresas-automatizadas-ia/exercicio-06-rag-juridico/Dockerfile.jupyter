# Jupyter sem ecrã — ver run_jupyter.sh
#
# `minimal-notebook:latest` pode trazer Python 3.13; em aarch64 o `chroma-hnswlib` (ChromaDB)
# frequentemente não tem wheel cp313 e falha a compilar («Unsupported compiler»).
# `python-3.12.11` mantém wheels binários alinhados ao ex. RAG auditoria / jurídico do curso.
FROM quay.io/jupyter/minimal-notebook:python-3.12.11

USER root
COPY requirements.txt /tmp/requirements-emp-jupyter.txt
RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir -r /tmp/requirements-emp-jupyter.txt \
  && fix-permissions "${CONDA_DIR}" \
  && fix-permissions "/home/${NB_USER}"

USER ${NB_UID}
