# Docker Compose lê o `.env` na RAIZ do repositório do curso (../../.env).

GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
# Opcional — só este exercício (senão usa GEMINI_MODEL / GEMINI_EMBEDDING_MODEL da raiz)
# GEMINI_MODEL_EX06=gemini-2.0-flash
# Embeddings: não usar text-embedding-004 (removido da API). Preferir gemini-embedding-001.
# Se ainda tiver text-embedding-004 na raiz, o código do ex06 remapeia para gemini-embedding-001.
# GEMINI_EMBEDDING_MODEL_EX06=gemini-embedding-001
# GEMINI_EMBEDDING_MODEL=gemini-embedding-001
PORT=8000
