# O Docker Compose deste exercício usa o ficheiro `.env` na RAIZ do repositório do curso
# (dois níveis acima desta pasta: ../../.env). Coloque lá as variáveis reais.
#
# Este ficheiro serve apenas de referência das chaves habituais.
# Documentação: https://ai.google.dev/

GOOGLE_API_KEY=

# Opcional (fallback: GEMINI_API_KEY)
# GEMINI_API_KEY=

GEMINI_MODEL=gemini-2.0-flash

GEMINI_RETRY_ATTEMPTS=5
GEMINI_RETRY_DELAY_SEC=2
