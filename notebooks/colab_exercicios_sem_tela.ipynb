      "source": [
        "## Exercício 0 — `exercicios/00_alo_mundo/main.py`\n",
        "\n",
        "Equivalente ao script mais simples: uma `HumanMessage` e imprimir a resposta."
      ],
      "id": "8a17823e"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "from langchain_core.messages import HumanMessage\n",
        "from langchain_google_genai import ChatGoogleGenerativeAI\n",
        "\n",
        "modelo = (os.environ.get(\"GEMINI_MODEL\") or \"gemini-2.0-flash\").strip() or \"gemini-2.0-flash\"\n",
        "print(f\"Modelo: {modelo}\", flush=True)\n",
        "llm = ChatGoogleGenerativeAI(model=modelo, temperature=0.2)\n",
        "print(\"A pedir resposta ao Gemini…\", flush=True)\n",
        "res = llm.invoke([HumanMessage(content=\"Responde só com: Olá, mundo!\")])\n",
        "texto = res.content if isinstance(res.content, str) else str(res.content)\n",
        "print(\"Resposta:\", flush=True)\n",
        "print(texto, flush=True)"
      ],
      "execution_count": null,
      "outputs": [],
      "id": "2fa5c27a"
    },
    {
      "cell_type": "markdown",
      "metadata": {},
      "source": [
        "## Exemplo — `SystemMessage` + `HumanMessage` (`exemplos/01_system_message_docker/`)"
      ],
      "id": "e49990fd"
    },
    {
      "cell_type": "code",
      "metadata": {},
      "source": [
        "import time\n",
        "from langchain_core.messages import AIMessage, HumanMessage, SystemMessage\n",
        "\n",
        "PERGUNTA = \"Diz em uma frase por que o system prompt influencia o estilo da resposta.\"  # ou altera aqui\n",
        "\n",
        "\n",
        "def _eh_429(exc: BaseException) -> bool:\n",
        "    t = str(exc).upper()\n",
        "    return \"429\" in t or \"RESOURCE_EXHAUSTED\" in t\n",
        "\n",
        "\n",
        "llm = ChatGoogleGenerativeAI(model=modelo, temperature=0.2)\n",
        "mensagens = [\n",
        "    SystemMessage(\n",
        "        content=(\n",
        "            \"És um assistente didático. Responde sempre em português europeu, \"\n",
        "            \"em no máximo duas frases curtas. Usa tom formal mas amigável.\"\n",
        "        )\n",
        "    ),\n",
        "    HumanMessage(content=PERGUNTA),\n",
        "]\n",
        "max_t = max(1, int(os.environ.get(\"GEMINI_RETRY_ATTEMPTS\", \"5\")))\n",
        "base = max(0.5, float(os.environ.get(\"GEMINI_RETRY_DELAY_SEC\", \"2\")))\n",
        "ultimo: BaseException | None = None\n",
        "\n",
        "for tentativa in range(max_t):\n",
        "    try:\n",
        "        res2: AIMessage = llm.invoke(mensagens)\n",
        "        texto2 = res2.content if isinstance(res2.content, str) else str(res2.content)\n",
        "        print(texto2, flush=True)\n",
        "        ultimo = None\n",
        "        break\n",
        "    except Exception as e:\n",
        "        ultimo = e\n",
        "        if _eh_429(e) and tentativa < max_t - 1:\n",
        "            time.sleep(min(base * (2**tentativa), 60.0))\n",
        "            continue\n",
        "        break\n",
        "\n",
        "if ultimo is not None:\n",
        "    if _eh_429(ultimo):\n",
        "        raise RuntimeError(f\"Erro 429 (quota). Modelo: `{modelo}`.\") from ultimo\n",
        "    raise ultimo"
      ],
      "execution_count": null,
      "outputs": [],
      "id": "179d8e46"
    },
