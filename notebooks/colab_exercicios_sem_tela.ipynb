      "source": [
        "import os\n",
        "\n",
        "# Preferir o armazenamento seguro do Colab (Secrets → GOOGLE_API_KEY)\n",
        "try:\n",
        "    from google.colab import userdata\n",
        "    _k = userdata.get(\"GOOGLE_API_KEY\")\n",
        "except Exception:\n",
        "    _k = None\n",
        "if not _k:\n",
        "    _k = os.environ.get(\"GOOGLE_API_KEY\") or os.environ.get(\"GEMINI_API_KEY\")\n",
        "if not _k:\n",
        "    from getpass import getpass\n",
        "    _k = getpass(\"Cole a GOOGLE_API_KEY (não aparece ao escrever): \").strip()\n",
        "os.environ[\"GOOGLE_API_KEY\"] = _k\n",
        "\n",
        "# Modelo (se 404, experimenta outro id listado na documentação Gemini)\n",
        "os.environ.setdefault(\"GEMINI_MODEL\", \"gemini-2.0-flash\")\n",
        "print(\"Modelo:\", os.environ[\"GEMINI_MODEL\"])"
      ],
      "execution_count": null,
