# Jupyter — ex. 6 sem ecrã (memória em LangChain / LCEL). Arranque: run_jupyter.sh .
FROM quay.io/jupyter/minimal-notebook:latest

USER root
COPY requirements.txt /tmp/requirements-ex06-sem.txt
RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir -r /tmp/requirements-ex06-sem.txt \
  && fix-permissions "${CONDA_DIR}" \
  && fix-permissions "/home/${NB_USER}"

USER ${NB_UID}
