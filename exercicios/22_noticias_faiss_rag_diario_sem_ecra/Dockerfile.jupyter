# Jupyter — ex. 22 sem ecrã (notícias + FAISS + RAG). Ver run_jupyter.sh .
FROM quay.io/jupyter/minimal-notebook:latest

USER root
COPY requirements.txt /tmp/requirements-ex22-sem.txt
RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir -r /tmp/requirements-ex22-sem.txt \
  && fix-permissions "${CONDA_DIR}" \
  && fix-permissions "/home/${NB_USER}"

USER ${NB_UID}
