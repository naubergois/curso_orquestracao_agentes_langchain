# RAG auditoria + rostos (LFW) — sem ecrã. Arranque: ./run_jupyter.sh
#
# `minimal-notebook:latest` traz Python 3.13+; em aarch64 o `chroma-hnswlib` (ChromaDB) muitas vezes
# não tem wheel cp313 e tenta compilar — falha com «Unsupported compiler» no detetor C++11.
# A etiqueta `python-3.12.11` alinha-se ao ex. 9 e mantém wheels binários estáveis.
FROM quay.io/jupyter/minimal-notebook:python-3.12.11

USER root
COPY requirements.txt /tmp/requirements-rag-audit.txt
RUN pip install --no-cache-dir --upgrade pip \
  && pip install --no-cache-dir -r /tmp/requirements-rag-audit.txt \
  && fix-permissions "${CONDA_DIR}" \
  && fix-permissions "/home/${NB_USER}"

USER ${NB_UID}
